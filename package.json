{
  "name": "web-app-template",
  "version": "0.0.0",
  "description": "web app template",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/app",
    "packages/test"
  ],
  "scripts": {
    "prebuild": "npm run generate:i18n-types & npm run generate:openapi-types",
    "build": "npx react-router build",
    "build:seed": "npx esbuild scripts/seed.ts --bundle --outfile=.artifacts/scripts/seed.js --platform=node --format=esm --packages=external",
    "build:migrate": "npx esbuild scripts/migrate.ts --bundle --outfile=.artifacts/scripts/migrate.js --platform=node --format=esm --packages=external",
    "build:scripts": "npm run build:seed && npm run build:migrate",
    "dev": "npx react-router dev --host",
    "start": "npx react-router-serve ./.artifacts/build/server/index.js",
    "typecheck": "npx tsc && npx eslint",
    "typecheck:rebuild": "npm run prebuild && npx react-router typegen && npm run typecheck",
    "generate:i18n-types": "npx tsx ./scripts/generate-i18n-types.ts",
    "generate:openapi": "npx tsx ./scripts/parse-openapi-docs.ts",
    "generate:openapi-types": "npm run generate:openapi && bash ./scripts/generate-openapi-types.sh",
    "generate:auth-schema": "npx @better-auth/cli generate --config src/features/auth/server/auth.ts --output src/features/auth/server/schema.ts --yes",
    "generate:migration": "npx drizzle-kit generate",
    "dev:migrate": "npx drizzle-kit migrate",
    "format": "npx eslint --fix",
    "dev:postgres": "docker compose -f ./docker/compose.base.yml -f ./docker/compose.dev.yml --project-directory . up postgres",
    "dev:postgres:down": "docker compose -f ./docker/compose.base.yml -f ./docker/compose.dev.yml down",
    "postgres:init": "npx tsx scripts/seed.ts",
    "test": "npx vitest run --config vite.test.config.ts",
    "test:unit": "npx vitest run --config vite.test.config.ts --mode unit",
    "test:integration": "npx vitest run --config vite.test.config.ts --mode integration",
    "test:component": "npx vitest run --config vite.test.config.ts --mode component",
    "playwright": "npm run playwright:e2e",
    "playwright:e2e": "npx playwright test --grep-invert @docshot",
    "playwright:docshot": "npx playwright test --grep @docshot --workers=1",
    "storybook": "npx storybook dev -p 6006",
    "build-storybook": "npx storybook build -o ./.artifacts/storybook-static"
  },
  "dependencies": {
    "@react-router/node": "7.13.2",
    "@react-router/serve": "7.13.2",
    "better-auth": "1.5.6",
    "drizzle-orm": "^0.41.0",
    "isbot": "^5.1.32",
    "pg": "^8.16.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "7.13.2",
    "serialize-javascript": "^7.0.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@react-router/dev": "7.13.2",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/serialize-javascript": "^5.0.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.1.10",
    "js-yaml": "^4.1.1",
    "openapi-typescript": "^7.10.1",
    "sass-embedded": "^1.97.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.3"
  },
  "engines": {
    "node": "=24"
  }
}
