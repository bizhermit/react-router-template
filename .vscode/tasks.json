{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "[git] cleanup branch",
      "group": "none",
      "type": "shell",
      "command": "bash scripts/git-cleanup-branch.sh"
    },
    {
      "label": "[git] merge default branch",
      "group": "none",
      "type": "shell",
      "command": "bash scripts/git-merge-default-branch.sh"
    },
    {
      "label": "[git] squash commits",
      "group": "none",
      "type": "shell",
      "command": "bash scripts/git-squash-commits.sh"
    },
    {
      "label": "[devcontainer] remove container&volumes",
      "group": "none",
      "type": "shell",
      "command": "bash .devcontainer/removeDocker.sh"
    },
    {
      "label": "[devcontainer] start postgres",
      "group": "none",
      "type": "shell",
      "command": "npm run dev:postgres"
    },
    {
      "label": "[generate] migration files",
      "group": "none",
      "type": "shell",
      "command": "npm run generate:migration"
    },
    {
      "label": "migrate",
      "group": "none",
      "type": "shell",
      "command": "npm run dev:migrate"
    },
    {
      "label": "typecheck",
      "group": "test",
      "type": "shell",
      "command": "npm run typecheck"
    },
    {
      "label": "format",
      "group": "none",
      "type": "shell",
      "command": "npm run format"
    },
    {
      "label": "[generate] i18n types",
      "group": "none",
      "type": "shell",
      "command": "npm run generate:i18n-types"
    },
    {
      "label": "[generate] openapi types",
      "group": "none",
      "type": "shell",
      "command": "npm run generate:openapi-types"
    },
    {
      "label": "playwright",
      "group": "test",
      "type": "shell",
      "command": "npm run playwright"
    },
    {
      "label": "no package-lock install",
      "group": "none",
      "type": "shell",
      "command": "npm install --no-package-lock"
    }
  ]
}